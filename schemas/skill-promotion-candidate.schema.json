{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Decodex Skill Promotion Candidate",
  "x-decodex-version": "0.1.7",
  "type": "object",
  "required": [
    "id",
    "skill_id",
    "skill_version",
    "project",
    "review_id",
    "status",
    "confidence",
    "recommendation",
    "valid_runs",
    "success_rate",
    "independent_projects",
    "cross_project_reuse",
    "independent_reuses",
    "unresolved_contradictions",
    "safety_failures",
    "human_decision",
    "promotion_executed",
    "decision_required",
    "evidence"
  ],
  "properties": {
    "id": { "type": "string" },
    "skill_id": { "type": "string" },
    "skill_version": { "type": "string" },
    "project": { "type": "string" },
    "review_id": { "type": "string" },
    "review_path": { "type": "string" },
    "report_path": { "type": "string" },
    "status": { "type": "string" },
    "scope": { "type": "string" },
    "confidence": { "type": "string" },
    "recommendation": { "type": "string" },
    "valid_runs": { "type": "integer" },
    "runs_total": { "type": "integer" },
    "successful_runs_total": { "type": "integer" },
    "success_rate": { "type": "number" },
    "independent_projects": { "type": "integer" },
    "cross_project_reuse": { "type": "boolean" },
    "independent_reuses": { "type": "integer" },
    "unresolved_contradictions": { "type": "integer" },
    "safety_failures": { "type": "integer" },
    "human_decision": { "type": "string" },
    "promotion_executed": { "type": "boolean" },
    "decision_required": { "type": "boolean" },
    "evidence": { "type": "array", "items": { "type": "string" } },
    "notes": { "type": "array", "items": { "type": "string" } }
  },
  "additionalProperties": true
}
