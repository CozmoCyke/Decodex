{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Decodex Skill",
  "type": "object",
  "required": [
    "id",
    "title",
    "version",
    "status",
    "scope"
  ],
  "properties": {
    "id": {
      "type": "string"
    },
    "title": {
      "type": "string"
    },
    "version": {
      "type": "string"
    },
    "status": {
      "type": "string",
      "enum": [
        "candidate",
        "draft",
        "validated",
        "deprecated"
      ]
    },
    "scope": {
      "type": "string",
      "enum": [
        "project",
        "global"
      ]
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  },
  "additionalProperties": true
}
