{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Decodex Skill",
  "x-decodex-version": "0.1.4",
  "type": "object",
  "required": [
    "id",
    "title",
    "version",
    "status",
    "scope"
  ],
  "properties": {
    "id": {
      "type": "string"
    },
    "title": {
      "type": "string"
    },
    "version": {
      "type": "string"
    },
    "status": {
      "type": "string",
      "enum": [
        "candidate",
        "experimental",
        "validated",
        "deprecated",
        "draft"
      ]
    },
    "scope": {
      "type": "string",
      "enum": [
        "project",
        "global"
      ]
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "confidence": {
      "type": "string"
    },
    "lifecycle": {
      "type": "object",
      "properties": {
        "state": {
          "type": "string",
          "enum": [
            "candidate",
            "experimental",
            "validated",
            "deprecated",
            "draft"
          ]
        },
        "latest_evaluation_id": {
          "type": "string"
        },
        "latest_review_id": {
          "type": "string"
        },
        "latest_revision_id": {
          "type": "string"
        },
        "latest_recommendation": {
          "type": "string"
        }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
